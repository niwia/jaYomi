# Optional: set a custom sukebei mirror if the main domain is blocked
# SUKEBEI_DOMAIN=https://sukebei.nyaa.iss.one

# Optional: HTTP proxy to bypass ISP blocks (e.g. http://user:pass@host:port)
# PROXY_URL=

# Port to run on (default: 7000)
# PORT=7000

# Public URL for the addon (important if deploying publicly)
# BASE_URL=http://127.0.0.1:7000
